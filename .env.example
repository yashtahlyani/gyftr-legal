# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.

# Supabase — Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# OpenAI key for AI clause analysis
VITE_OPENAI_API_KEY=your-openai-key

# Google integration (Picker / Drive / Docs).
# Restrict the API keys by HTTP referrer in the Google Cloud Console.
VITE_GOOGLE_DOCS_API_KEY=your-google-docs-api-key
VITE_GOOGLE_DRIVE_API_KEY=your-google-drive-api-key
VITE_GOOGLE_PICKER_API_KEY=your-google-picker-api-key
VITE_GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com

# --- Server-side only (set via `supabase secrets set`, not here) ---
# CLAUDE_API_KEY=
# ADOBE_CLIENT_ID=
# ADOBE_CLIENT_SECRET=
